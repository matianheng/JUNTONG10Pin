<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Disabled State -->
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/c444444" /> <!-- Disabled color -->
        </shape>
    </item>
    <!-- Enabled State -->
    <item android:state_enabled="true">
        <ripple android:color="@color/c3363FC"> <!-- Ripple color for enabled state -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/c3363FC" /> <!-- Enabled color -->
                </shape>
            </item>
        </ripple>
    </item>
</selector>