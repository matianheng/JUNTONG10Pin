<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:paddingTop="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_5"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/c444444"
            android:textSize="@dimen/sp_15"
            android:text=""
            android:gravity="center"/>
        <TextView
            android:id="@+id/tv_ad"
            android:layout_width="0dp"
            android:layout_weight="1.25"
            android:layout_height="wrap_content"
            android:textColor="@color/c444444"
            android:textSize="@dimen/sp_15"
            android:text=""
            android:gravity="center"/>
        <TextView
            android:id="@+id/tv_actual"
            android:layout_width="0dp"
            android:layout_weight="1.25"
            android:layout_height="wrap_content"
            android:textColor="@color/c444444"
            android:textSize="@dimen/sp_15"
            android:text=""
            android:gravity="center"/>
        <LinearLayout
            android:id="@+id/ll_zero_adjustment"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tv_zero_adjustment"
                android:layout_width="72dp"
                android:background="@drawable/blue_bg_circle"
                android:layout_height="@dimen/dp_26"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_15"
                android:text="@string/zero_adjustment"
                android:gravity="center"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ll_fill_up"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tv_fill_up"
                android:layout_width="72dp"
                android:background="@drawable/blue_bg_circle"
                android:layout_height="@dimen/dp_26"
                android:textColor="@color/white"
                android:textSize="@dimen/sp_15"
                android:text="@string/fill_up"
                android:gravity="center"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>