        android:layout_height="@dimen/dp_0"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/dp_8"
        android:paddingBottom="@dimen/dp_8"
        app:layout_constraintBottom_toTopOf="@id/cl_bottom"
        app:layout_constraintTop_toBottomOf="@id/cl_top">
        <LinearLayout
            android:padding="@dimen/dp_10"
            android:orientation="vertical"
            android:background="@drawable/main_state_bg"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/leg_state_icon"/>
                <TextView
                    android:id="@+id/tv_leg_state"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_width="@dimen/dp_60"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    android:text="-"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:background="@color/cAFECEE"/>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/fifth_leg_state_icon"/>
                <TextView
                    android:id="@+id/tv_fifth_leg_state"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_width="@dimen/dp_60"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    android:text="-"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:background="@color/cAFECEE"/>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/arm_length_icon"/>
                <TextView
                    android:id="@+id/tv_arm_length"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_width="@dimen/dp_60"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    android:text="-"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:background="@color/cAFECEE"/>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1">
                <ImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/work_area_icon"/>
                <TextView
                    android:id="@+id/tv_work_area"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_width="@dimen/dp_60"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    android:text="-"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:background="@color/cAFECEE"/>
            <LinearLayout
                android:id="@+id/ll_adh"
                android:layout_marginTop="5dp"
                android:gravity="center"
                android:background="@drawable/main_adh_frame_bg"
