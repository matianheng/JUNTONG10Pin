<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingTop="@dimen/dp_5"
        android:paddingBottom="@dimen/dp_5"
        android:id="@+id/cl_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="@dimen/dp_8"
            android:background="@color/c15606060"
            android:padding="@dimen/dp_5">
            <LinearLayout
                android:orientation="horizontal"
                android:background="@color/c00000F"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="match_parent">
                <ProgressBar
                    android:id="@+id/progress_mini"
                    android:max="100"
                    android:progress="0"
                    android:layout_gravity="center"
                    style="@style/ProgressBar_Mini"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"/>
                <TextView
                    android:id="@+id/tv_moment_percentage"
                    android:layout_width="@dimen/dp_75"
                    android:gravity="center_horizontal"
                    android:layout_height="match_parent"
                    android:text="0.0%"
                    android:textSize="@dimen/sp_18"
                    android:textColor="@color/white"/>
            </LinearLayout>
            <TextView
                android:id="@+id/tv_date"
                android:layout_marginLeft="25dp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="2023-01-01 00:00:00"
                android:textSize="@dimen/sp_18"
                android:textColor="@color/white"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/cl_bottom"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_60"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp_16"
            android:scaleType="fitXY"
            android:layout_gravity="bottom"/>
        <LinearLayout
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:id="@+id/ll_leg_state"
                android:background="@drawable/main_btn_1"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_52">
                <ImageView
                    android:id="@+id/iv_leg_state"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/half_state_icon"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_section_arm"
                android:layout_marginLeft="5dp"
                android:background="@drawable/main_btn_2"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:id="@+id/iv_section_arm"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/section_arm_icon"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_work_arm"
                android:background="@drawable/main_btn_3"
                android:layout_marginLeft="5dp"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_45">
                <ImageView
                    android:id="@+id/iv_work_arm"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/big_hook_icon"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_magnification"
                android:background="@drawable/main_btn_4"
                android:gravity="center"
                android:layout_marginLeft="5dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_40">
                <ImageView
                    android:layout_width="@dimen/dp_28"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/magnification_white_icon"/>
                <TextView
                    android:id="@+id/tv_magnification"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    android:text="-"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_quick_view"
                android:background="@drawable/main_btn_5"
                android:gravity="center"
                android:layout_marginLeft="5dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_40">
                <ImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/quick_view_icon"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_voice"
                android:background="@drawable/main_btn_6"
                android:layout_marginLeft="5dp"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_45">
                <ImageView
                    android:id="@+id/iv_voice"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/voice_on_icon"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_state"
                android:background="@drawable/main_btn_7"
                android:layout_marginLeft="5dp"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_48">
                <ImageView
                    android:layout_width="@dimen/dp_26"
                    android:layout_height="@dimen/dp_28"
                    android:src="@drawable/state_icon"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_set_up"
                android:background="@drawable/main_btn_8"
                android:gravity="center"
                android:layout_marginLeft="5dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/dp_52">
                <ImageView
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_32"
                    android:src="@drawable/menu_icon"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

