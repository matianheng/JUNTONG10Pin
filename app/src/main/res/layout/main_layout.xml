            android:layout_weight="2.4"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="@dimen/dp_15"
                android:scaleType="fitXY"
                android:src="@drawable/vehicle_model_icon" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:visibility="gone"
                android:src="@drawable/vehicle_model_bg"/>
            <ImageView
                android:layout_marginLeft="@dimen/dp_8"
                android:layout_width="@dimen/dp_45"
                android:layout_height="@dimen/dp_30"
                android:src="@drawable/logo_icon"/>
            <LinearLayout
                android:layout_gravity="bottom"
                android:gravity="center_horizontal"
                android:layout_marginLeft="@dimen/dp_8"
                android:layout_marginBottom="@dimen/dp_20"
                android:background="@drawable/maximum_display_icon"
                android:layout_width="@dimen/dp_60"
                android:layout_height="@dimen/dp_100"
                android:orientation="vertical">
                <TextView
                    android:layout_marginTop="@dimen/dp_20"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="t"
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/c6699CC"/>
                <TextView
                    android:id="@+id/tv_actual_weight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/white"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="max t"
                    android:textSize="@dimen/sp_14"
                    android:textColor="@color/c6699CC"/>
                <TextView
                    android:id="@+id/tv_frontal_weight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="@dimen/sp_16"
                    android:textColor="@color/white"/>
            </LinearLayout>
            <LinearLayout
                android:layout_gravity="right"
                android:gravity="center"
                android:layout_marginRight="@dimen/dp_10"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dp_26">
                <ImageView
                    android:id="@+id/iv_virtual_wall_alarm"
                    android:layout_marginRight="@dimen/dp_5"
                    android:visibility="gone"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    android:src="@drawable/virtual_wall_alarm_icon"/>
                <ImageView
                    android:id="@+id/iv_amplitude"
                    android:visibility="gone"
                    android:layout_marginRight="@dimen/dp_5"
                    android:layout_width="@dimen/dp_20"
                    android:layout_height="@dimen/dp_20"
                    android:src="@drawable/amplitude_alarm_icon"/>
                <ProgressBar
                    android:id="@+id/progressBar_amplitude"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="@dimen/dp_120"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/progress_bar_drawable" />
                <TextView
                    android:id="@+id/tv_percentage_amplitude"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:text="0%" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_fault_alarm"
                android:visibility="gone"
                android:layout_gravity="right"
                android:gravity="center"
                android:layout_marginRight="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_18"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tv_fault_alarm"
                    android:gravity="center|right"
                    android:layout_gravity="center"
                    android:layout_width="200dp"
                    android:layout_height="@dimen/dp_28"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/colorAccent"
                    android:text="" />
            </LinearLayout>
            <LinearLayout
                android:id="@+id/ll_jib"
                android:visibility="gone"
                android:layout_marginRight="@dimen/dp_10"
                android:layout_marginTop="@dimen/dp_44"
                android:gravity="center|right"
                android:layout_gravity="right"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:background="@drawable/real_time_status_bg"
                    android:paddingLeft="@dimen/dp_2"
                    android:paddingRight="@dimen/dp_2"
                    android:orientation="vertical"
                    android:layout_width="wrap_content"
                    android:gravity="center"
                    android:layout_height="@dimen/dp_25">
                    <ImageView
                        android:layout_width="@dimen/dp_28"
                        android:layout_height="@dimen/dp_18"
                        android:src="@drawable/jib_state_icon"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_marginLeft="@dimen/dp_5"
                    android:background="@drawable/real_time_status_bg"
                    android:paddingLeft="@dimen/dp_2"
                    android:paddingRight="@dimen/dp_2"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dp_25">
                    <TextView
                        android:id="@+id/tv_jib_length"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:text="-"/>
                    <TextView
                        android:layout_marginLeft="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:text="m /"/>
                    <TextView
                        android:id="@+id/tv_jib_angle"
                        android:layout_marginLeft="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:text="-"/>
                    <TextView
                        android:layout_marginLeft="2dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:text="°"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/tv_height"
                android:background="@drawable/real_time_status_bg"
                android:gravity="center"
                android:layout_width="@dimen/dp_55"
                android:layout_height="@dimen/dp_22"
                android:layout_marginLeft="@dimen/dp_28"
                android:layout_marginTop="@dimen/dp_58"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:text="00.0 m"/>
            <TextView
                android:id="@+id/tv_length"
                android:background="@drawable/real_time_status_bg"
                android:layout_gravity="right"
                android:gravity="center"
                android:layout_width="@dimen/dp_55"
                android:layout_height="@dimen/dp_22"
                android:layout_marginRight="@dimen/dp_100"
                android:layout_marginTop="@dimen/dp_68"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:text="00.0 m"/>
            <TextView
                android:id="@+id/tv_angle"
                android:background="@drawable/real_time_status_bg"
                android:layout_gravity="right"
                android:gravity="center"
                android:layout_width="@dimen/dp_55"
                android:layout_height="@dimen/dp_22"
                android:layout_marginRight="@dimen/dp_160"
                android:layout_marginTop="@dimen/dp_110"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:text="00.0 °"/>
            <TextView
                android:id="@+id/tv_counterweight"
                android:visibility="gone"
                android:background="@drawable/real_time_status_bg"
                android:layout_gravity="right|bottom"
                android:gravity="center"
                android:layout_width="@dimen/dp_55"
                android:layout_height="@dimen/dp_22"
                android:layout_marginRight="@dimen/dp_10"
                android:layout_marginBottom="@dimen/dp_100"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:text="00.0 t"/>
            <TextView
                android:id="@+id/tv_amplitude"
                android:background="@drawable/real_time_status_bg"
                android:layout_gravity="bottom|center"
                android:gravity="center"
                android:layout_width="@dimen/dp_55"
                android:layout_height="@dimen/dp_22"
                android:layout_marginLeft="@dimen/dp_15"
                android:layout_marginBottom="@dimen/dp_10"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:text="00.0 m"/>
            <LinearLayout
                android:id="@+id/ll_counter_weight"
                android:layout_gravity="bottom|right"
                android:layout_marginBottom="@dimen/dp_8"
                android:gravity="center|right"
                android:layout_marginRight="@dimen/dp_10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_marginLeft="@dimen/dp_8"
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_22"
                    android:src="@drawable/counter_weight_icon"/>
                <TextView
                    android:id="@+id/tv_counter_weight"
                    android:layout_marginLeft="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:text="-"/>
            </LinearLayout>
        </FrameLayout>
        <LinearLayout
            android:padding="@dimen/dp_10"
            android:orientation="vertical"
            android:background="@drawable/main_state_bg"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent">
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1">
                <ImageView
                    android:id="@+id/iv_blue_work_arm"
                    android:layout_width="@dimen/dp_32"
                    android:layout_height="@dimen/dp_26"
                    android:src="@drawable/big_hook_blue_icon"/>
                <TextView
                    android:id="@+id/tv_work_arm"
                    android:layout_marginLeft="@dimen/dp_5"
                    android:layout_width="@dimen/dp_60"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    android:text="-"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:background="@color/cAFECEE"/>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_0"
                android:layout_weight="1">
