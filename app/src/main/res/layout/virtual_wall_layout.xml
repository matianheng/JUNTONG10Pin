<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:keyboard="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/main_bg"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_50">

        <LinearLayout
            android:id="@+id/ll_return"
            android:layout_width="@dimen/dp_120"
            android:layout_height="match_parent"
            android:layout_alignParentLeft="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="@dimen/dp_30"
                android:layout_height="@dimen/dp_30"
                android:layout_marginLeft="@dimen/dp_12"
                android:src="@drawable/return_icon" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/virtual_wall"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_20" />
    </RelativeLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/ll_virtual_wall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/virtual_wall"
                android:textColor="@color/white"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/switch_virtual_wall"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:layout_gravity="center_vertical"
                android:thumb="@drawable/switch_setting_selector_thumb"
                android:track="@drawable/switch_setting_selector_track" />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ll_virtual_wall_show"
            android:background="@drawable/white_frame_circle"
            android:padding="@dimen/dp_10"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="@dimen/dp_15"
            android:layout_marginBottom="@dimen/dp_10"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_gravity="center_vertical"
                    android:gravity="center_vertical"
                    android:layout_marginRight="@dimen/dp_10"
                    android:layout_marginBottom="@dimen/dp_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tv1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/height_virtual_wall_setting"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv2"
                        android:layout_width="150dp"
                        android:gravity="right"
                        android:layout_height="wrap_content"
                        android:text="@string/real_time_value"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv_height_real_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp_5"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginRight="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/upper_limit_value"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_upper_limit_value"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginRight="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lower_limiting_value"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_lower_limiting_value"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginRight="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/upper_deceleration_zone"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_upper_deceleration_zone"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginRight="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lower_deceleration_zone"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_lower_deceleration_zone"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <TextView
                    android:id="@+id/tv_height_zero_value_reset"
                    android:layout_marginTop="@dimen/dp_20"
                    android:layout_width="@dimen/dp_100"
                    android:layout_height="@dimen/dp_30"
                    android:text="@string/zero_value_reset"
                    android:background="@drawable/blue_bg_circle"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_15"/>
            </LinearLayout>
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/white"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_gravity="center_vertical"
                    android:gravity="center_vertical"
                    android:layout_marginLeft="@dimen/dp_10"
                    android:layout_marginBottom="@dimen/dp_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tv7"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/amplitude_virtual_wall_setting"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv8"
                        android:layout_width="150dp"
                        android:gravity="right"
                        android:layout_height="wrap_content"
                        android:text="@string/real_time_value"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv_amplitude_real_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/dp_5"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/maximum_value"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_maximum_value"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv10"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/minimum_value"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_minimum_value"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv11"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/maximum_deceleration_zone"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_maximum_deceleration_zone"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <LinearLayout
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="@dimen/dp_10"
                    android:layout_height="@dimen/dp_35">
                    <TextView
                        android:id="@+id/tv12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/minimum_deceleration_zone"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                    <com.android.sdk.kb.AutoKeyboardEditText
                        android:id="@+id/et_minimum_deceleration_zone"
                        android:layout_width="0dp"
                        android:background="@null"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:gravity="center|right"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/white"
                        android:inputType="number"
                        android:textColorHint="@color/cD2D6DE"
                        android:hint="@string/enter"
                        android:text=""
                        keyboard:xmlLayoutResId="@xml/keyboard_numeric"/>
                    <TextView
                        android:layout_marginLeft="@dimen/dp_5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="m"
                        android:textColor="@color/white"
                        android:textSize="@dimen/sp_14"/>
                </LinearLayout>
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_0_1"
                    android:background="@color/white"/>
                <TextView
                    android:id="@+id/tv_amplitude_zero_value_reset"
                    android:layout_marginTop="@dimen/dp_20"
                    android:layout_width="@dimen/dp_100"
                    android:layout_height="@dimen/dp_30"
                    android:text="@string/zero_value_reset"
                    android:background="@drawable/blue_bg_circle"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_15"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:id="@+id/tv_save"
            android:layout_marginBottom="@dimen/dp_15"
            android:layout_width="@dimen/dp_120"
            android:layout_height="@dimen/dp_32"
            android:text="@string/save"
            android:background="@drawable/blue_bg_circle"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_16"/>
    </LinearLayout>
</LinearLayout>